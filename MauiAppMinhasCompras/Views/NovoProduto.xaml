<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="OnSalvar"/>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Descrição" />
        <Entry x:Name="txt_descricao" />

        <Label Text="Quantidade" />
        <Entry x:Name="txt_quantidade" Keyboard="Numeric" />

        <Label Text="Preço" />
        <Entry x:Name="txt_preco" Keyboard="Numeric" />

        <Label Text="Categoria" />
        <Entry x:Name="txt_categoria" Placeholder="Ex: Alimentos, Limpeza..." />

    </VerticalStackLayout>

</ContentPage>